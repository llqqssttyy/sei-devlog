---
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import config from '../../astro-theme-config';
import pretendardFontUrl from '../assets/fonts/pretendard-variable.woff2';
import { SITE_TITLE, SITE_AUTHOR, SITE_LOCALE } from '../consts';
import { isCommentsModeEnabled, parseCommentsMode, parseEnabledFlag } from '../lib/parse';
import {
  createWebsiteJsonLd,
  resolveCanonicalUrl,
  resolveDocumentTitle,
  resolveOgImageUrl,
  resolvePageUrl,
} from '../lib/seo';
import { withBase } from '../utils/paths';
import { serializeScriptJson } from '../utils/serialize-script-json';

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata;
  /** Pre-built OG image URL string — overrides image.src when provided */
  ogImageUrl?: string;
  /** 'website' (default) | 'article' */
  type?: 'website' | 'article';
  /** ISO date string — article published_time */
  pubDate?: string;
  /** ISO date string — article modified_time */
  updatedDate?: string;
  /** Robots meta content. Defaults to public indexing. */
  robots?: string;
  /** Canonical URL override for special routes such as 404.html. */
  canonicalUrl?: string;
  /** Social URL override for special routes such as 404.html. */
  pageUrl?: string;
  /** Open Graph locale override for localized routes. */
  locale?: string;
}

const {
  title,
  description,
  image,
  ogImageUrl,
  type = 'website',
  pubDate,
  updatedDate,
  robots = 'index, follow',
  canonicalUrl,
  pageUrl,
  locale,
} = Astro.props;

const analyticsEnabled = parseEnabledFlag(import.meta.env.PUBLIC_VERCEL_ANALYTICS);
const commentsMode = parseCommentsMode(import.meta.env.PUBLIC_GISCUS_MODE, config.comments.mode);
const commentsEnabled = isCommentsModeEnabled(commentsMode);
const siteUrl = Astro.site ?? Astro.url;
const canonicalURL = resolveCanonicalUrl({
  canonicalUrl,
  pathname: Astro.url.pathname,
  site: siteUrl,
});
const ogLocale = locale ?? SITE_LOCALE;
const documentTitle = resolveDocumentTitle(title);
const fallbackOgImageUrl = config.site.defaultOgImage;
const ogImage = resolveOgImageUrl({
  ogImageUrl,
  imageSrc: image?.src,
  currentUrl: Astro.url,
  site: siteUrl,
  fallbackOgImageUrl,
});
const canonicalHref = canonicalURL.toString();
const siteHref = new URL(withBase('/'), siteUrl).toString();
const searchHref = new URL(withBase('/search'), siteUrl).toString();
const rssHref = new URL(withBase('/rss.xml'), siteUrl).toString();
const sitemapHref = new URL(withBase('/sitemap-index.xml'), siteUrl).toString();
const pageHref = resolvePageUrl({ pageUrl, currentUrl: Astro.url, site: siteUrl });
const ogImageHref = ogImage?.toString();

// WebSite JSON-LD for website pages only.
const websiteJsonLd =
  type === 'website' ? serializeScriptJson(createWebsiteJsonLd({ siteHref, searchHref })) : null;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<!-- Theme init — runs early to prevent FOUC -->
<script is:inline>
  (function () {
    let d;
    try {
      d =
        localStorage.getItem('theme') ||
        (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    } catch {
      d = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    const el = document.documentElement;
    el.setAttribute('data-theme', d);
    el.classList.add('no-transitions');
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        el.classList.remove('no-transitions');
      });
    });
  })();
</script>

<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} sizes="any" />
<link rel="icon" type="image/png" href={withBase('/favicon-32x32.png')} sizes="32x32" />
<link rel="icon" type="image/png" href={withBase('/favicon-16x16.png')} sizes="16x16" />
<link rel="shortcut icon" href={withBase('/favicon.ico')} />
<link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
<link rel="sitemap" href={sitemapHref} />
<link rel="preload" href={pretendardFontUrl} as="font" type="font/woff2" crossorigin />
{
  commentsEnabled && (
    <>
      <link rel="preconnect" href="https://giscus.app" crossorigin />
      <link rel="preconnect" href="https://github.com" crossorigin />
    </>
  )
}
<meta name="theme-color" content="#f7fbfd" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#18181b" media="(prefers-color-scheme: dark)" />
<link rel="alternate" type="application/rss+xml" title={`${SITE_TITLE} RSS`} href={rssHref} />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content={robots} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalHref} />

<!-- Primary Meta Tags -->
<title>{documentTitle}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content={SITE_AUTHOR} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={pageHref} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{ogImageHref && <meta property="og:image" content={ogImageHref} />}
{ogImageHref && <meta property="og:image:width" content={String(image?.width ?? 1200)} />}
{ogImageHref && <meta property="og:image:height" content={String(image?.height ?? 630)} />}
{ogImageHref && <meta property="og:image:alt" content={title} />}
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content={SITE_TITLE} />
{type === 'article' && pubDate && <meta property="article:published_time" content={pubDate} />}
{
  type === 'article' && updatedDate && (
    <meta property="article:modified_time" content={updatedDate} />
  )
}
{type === 'article' && <meta property="article:author" content={SITE_AUTHOR} />}

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={pageHref} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImageHref && <meta name="twitter:image" content={ogImageHref} />}
{ogImageHref && <meta name="twitter:image:alt" content={title} />}

<!-- JSON-LD (WebSite schema) -->
{websiteJsonLd && <script is:inline type="application/ld+json" set:html={websiteJsonLd} />}

<!-- Vercel Analytics (opt-in: PUBLIC_VERCEL_ANALYTICS=true) -->
{analyticsEnabled && <script is:inline defer src="/_vercel/insights/script.js" />}
