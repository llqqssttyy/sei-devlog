---
import { render } from 'astro:content';
import { getPostEntries, type PostEntry } from '../../content/post-queries';
import {
  getReadingTimeMinutes,
  isPublishedPost,
  selectRelatedPosts,
  sortPostsByNewest,
} from '../../content/post-helpers';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const allPosts = sortPostsByNewest((await getPostEntries()).filter(isPublishedPost));

  return allPosts.map((post) => {
    const slug = post.id;
    return {
      params: { slug },
      props: {
        post,
        relatedPosts: selectRelatedPosts(allPosts, post),
      },
    };
  });
}

interface Props {
  post: PostEntry;
  relatedPosts: PostEntry[];
}

const { post, relatedPosts } = Astro.props;
const { Content } = await render(post);

const readingTime = getReadingTimeMinutes(post.body);
---

<PostLayout
  {...post.data}
  readingTime={readingTime}
  focusEffect={post.data.focusEffect}
  relatedPosts={relatedPosts}
>
  <Content />
</PostLayout>
