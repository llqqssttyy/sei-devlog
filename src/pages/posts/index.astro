---
import '../../styles/pages/posts-index.css';
import { getCollection } from 'astro:content';
import PostFeed from '../../components/PostFeed.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION } from '../../consts';
import { getUiText } from '../../ui';

const tr = getUiText();

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={tr.postsTitle} description={SITE_DESCRIPTION}>
  <main id="main-content" class="posts-main">
    <div class="posts-header">
      <div>
        <p class="posts-label eyebrow-accent">{tr.postsEyebrow}</p>
        <h1 class="posts-title">{tr.postsTitle}</h1>
      </div>
    </div>

    <PostFeed posts={posts} basePath="/posts" initialVisible={8} />
  </main>
</BaseLayout>
