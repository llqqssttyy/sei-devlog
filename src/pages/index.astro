---
import '../styles/pages/home.css';
import { Image, getImage } from 'astro:assets';
import { getCollection } from 'astro:content';
import FeaturedPostGrid from '../components/FeaturedPostGrid.astro';
import FormattedDate from '../components/FormattedDate.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { DATE_LOCALE, SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getUiText } from '../ui';
import { withBase } from '../utils/paths';
const tr = getUiText();

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts.find((post) => post.data.homeFeatured) ?? posts[0];
const heroCandidates = posts.filter((post) => post.id !== featured?.id);
const pinnedHeroPosts = posts
  .filter((post) => post.id !== featured?.id && post.data.homeHeroOrder)
  .sort((a, b) => {
    const orderDelta = (a.data.homeHeroOrder ?? 0) - (b.data.homeHeroOrder ?? 0);
    if (orderDelta !== 0) return orderDelta;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  });
const fallbackHeroPosts = heroCandidates.filter((post) => !post.data.homeHeroOrder);
const heroPosts = [...pinnedHeroPosts, ...fallbackHeroPosts].slice(0, 2);
const heroDateFormatter = new Intl.DateTimeFormat(DATE_LOCALE, {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
const getHeroDateParts = (date: Date) => {
  const parts = heroDateFormatter.formatToParts(date);
  return {
    label: heroDateFormatter.format(date),
    parts,
  };
};
const gridCandidates = posts.filter((post) => post.id !== featured?.id);
const pinnedGridPosts = gridCandidates
  .filter((post) => post.data.homeOrder)
  .sort((a, b) => {
    const orderDelta = (a.data.homeOrder ?? 0) - (b.data.homeOrder ?? 0);
    if (orderDelta !== 0) return orderDelta;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  });
const fallbackGridPosts = gridCandidates.filter((post) => !post.data.homeOrder);
const gridPosts = [...pinnedGridPosts, ...fallbackGridPosts].slice(0, 3);
const featuredPlaceholder = featured?.data.heroImage
  ? await getImage({
      src: featured.data.heroImage,
      width: 48,
      format: 'webp',
      quality: 28,
    })
  : undefined;
const featuredPlaceholderStyle = featuredPlaceholder
  ? `--tone-image-placeholder: url("${featuredPlaceholder.src}");`
  : undefined;
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <main id="main-content" class="home-main">
    <section class="hero">
      <h1 class="hero-title">
        <span class="hero-title-line">{tr.heroTitle}</span>
        {
          tr.heroTitleLine2 && (
            <span class="hero-title-line hero-title-line--accent">{tr.heroTitleLine2}</span>
          )
        }
      </h1>

      <p class="hero-desc">{SITE_DESCRIPTION}</p>

      <div class="hero-divider" aria-hidden="true"></div>

      {
        heroPosts.length > 0 && (
          <nav class="hero-recent" aria-label="Selected posts">
            <div class="hero-recent-list">
              {
                heroPosts.map((post) => {
                  const heroDate = getHeroDateParts(post.data.pubDate);

                  return (
                    <a href={withBase(`/posts/${post.id}/`)} class="hero-recent-item">
                      <span class="hero-recent-main">
                        <span class="hero-recent-title">{post.data.title}</span>
                        <span class="hero-recent-arrow" aria-hidden="true">
                          ↗
                        </span>
                      </span>
                      <span class="hero-recent-date">
                        <time datetime={post.data.pubDate.toISOString()} aria-label={heroDate.label}>{
                          heroDate.parts.map((part) => (
                            <span class={`hero-recent-date-${part.type}`}>{part.value}</span>
                          ))
                        }</time>
                      </span>
                    </a>
                  );
                })
              }
            </div>
          </nav>
        )
      }
    </section>

    {
      featured && (
        <section class="featured-section">
          <a href={withBase(`/posts/${featured.id}/`)} class="featured-card">
            <div class="featured-text">
              <p class="featured-meta">
                <FormattedDate date={featured.data.pubDate} />
              </p>
              <h2 class="featured-title">{featured.data.title}</h2>
              {featured.data.description && (
                <p class="featured-desc">{featured.data.description}</p>
              )}
              <span class="featured-cta">{tr.readLink}</span>
            </div>
            <div class="featured-thumb-wrap" style={featuredPlaceholderStyle}>
              {featured.data.heroImage ? (
                <Image
                  src={featured.data.heroImage}
                  alt={featured.data.title}
                  class="featured-thumb"
                  widths={[400, 720, 960, 1280]}
                  sizes="(max-width: 600px) calc(100vw - 32px), 360px"
                  quality={88}
                  loading="lazy"
                />
              ) : (
                <div class="featured-thumb card-img-placeholder" />
              )}
            </div>
          </a>
        </section>
      )
    }

    {
      gridPosts.length > 0 && (
        <section class="posts-section">
          <div class="posts-header">
            <a href={withBase('/posts')} class="view-all">
              {tr.viewAll}
            </a>
          </div>
          <FeaturedPostGrid posts={gridPosts} />
        </section>
      )
    }
  </main>
</BaseLayout>
