---
import '../styles/pages/about.css';
import config from '../../astro-theme-config';
import AboutCareerSection from '../components/about/AboutCareerSection.astro';
import AboutFocusSection from '../components/about/AboutFocusSection.astro';
import AboutHero from '../components/about/AboutHero.astro';
import AboutProfilePanel from '../components/about/AboutProfilePanel.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const profileImageUrl = config.about.profileImage.trim();
const profileName = config.about.name || config.site.author;
const profileRole = config.about.role;
const profileLocation = config.about.location;
const profileFocus = config.about.focus;
const profileLead = config.about.lead;
const careerLabel = config.about.careerLabel;
const careerItems = config.about.career;
const focusItems = config.about.interests;
const interestsLabel = config.about.interestsLabel;
const interestsHeading = config.about.interestsHeading;
const profileLinks = [
  {
    label: 'GitHub',
    href: config.social.github,
  },
  {
    label: 'Website',
    href: config.social.website,
  },
  {
    label: 'LinkedIn',
    href: config.social.linkedin,
  },
  {
    label: 'Email',
    href: config.social.email ? `mailto:${config.social.email}` : '',
  },
].filter((link) => link.href);
---

<BaseLayout title="About" description={profileLead}>
  <main id="main-content" class="about-main">
    <section class="about-hero" aria-labelledby="about-title">
      <AboutHero headline={config.about.headline} lead={profileLead} />
      <AboutProfilePanel
        imageUrl={profileImageUrl}
        name={profileName}
        role={profileRole}
        location={profileLocation}
        focus={profileFocus}
        links={profileLinks}
      />
    </section>

    <!-- <AboutStatementSection label={statementLabel} title={statementTitle} statement={statement} /> -->
    <AboutCareerSection label={careerLabel} items={careerItems} />
    <AboutFocusSection label={interestsLabel} heading={interestsHeading} items={focusItems} />
  </main>
</BaseLayout>
